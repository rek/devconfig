#!/bin/bash
# Install zellij terminal multiplexer
set -e

DEST="$HOME/.local/bin"
mkdir -p "$DEST"

ARCH=$(uname -m)
case "$ARCH" in
  x86_64)  TARGET="x86_64-unknown-linux-musl" ;;
  aarch64) TARGET="aarch64-unknown-linux-musl" ;;
  *) echo "Unsupported arch: $ARCH"; exit 1 ;;
esac

echo "Installing zellij for $TARGET..."
curl -sS -L "https://github.com/zellij-org/zellij/releases/latest/download/zellij-${TARGET}.tar.gz" | tar xz -C "$DEST"
chmod +x "$DEST/zellij"
echo "Installed: $("$DEST/zellij" --version)"
